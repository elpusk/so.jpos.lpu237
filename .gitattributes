# ──────────────────────────────────────────────────────────────────────────────
# .gitattributes
# 목적:
#   1) gradlew 의 실행 권한(chmod +x)을 git 이 보존하도록 강제
#      → Windows 에서 커밋해도 Linux clone 시 +x 가 유지됨
#   2) 줄 끝(line ending) 정책 명시
#      → .bat / .sh 가 혼재하므로 파일 종류별로 명확히 지정
# ──────────────────────────────────────────────────────────────────────────────

# 기본: 텍스트 파일은 LF 로 정규화
* text=auto

# Shell script — LF 고정 + 실행 권한 유지
*.sh    text eol=lf
gradlew text eol=lf

# Windows batch — CRLF 고정
*.bat   text eol=crlf

# Java / Gradle 소스 — LF
*.java      text eol=lf
*.gradle    text eol=lf
*.properties text eol=lf
*.xml       text eol=lf
*.md        text eol=lf

# 바이너리 — diff/merge 비활성화
*.jar   binary
*.dll   binary
*.so    binary
*.so.*  binary
*.class binary
*.pdf   binary
